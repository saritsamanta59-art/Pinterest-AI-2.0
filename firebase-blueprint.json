{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile information, linked to Firebase Auth UID.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL to the user's profile picture."
        },
        "bio": {
          "type": "string",
          "description": "A short biography of the user."
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark", "system"],
          "description": "The user's preferred UI theme."
        },
        "geminiApiKey": {
          "type": "string",
          "description": "The user's personal Gemini API key."
        },
        "pinterestAccounts": {
          "type": "array",
          "description": "List of connected Pinterest accounts (max 10).",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "token": { "type": "string" }
            },
            "required": ["id", "name", "token"]
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the profile was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the profile was last updated."
        }
      },
      "required": ["uid", "email", "createdAt", "updatedAt"]
    },
    "Pin": {
      "title": "Pin",
      "description": "Stores a Pinterest pin created or scheduled by the user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "pinterestPinId": {
          "type": "string",
          "description": "The ID of the pin returned by Pinterest API."
        },
        "accountId": {
          "type": "string",
          "description": "The ID of the Pinterest account."
        },
        "boardId": {
          "type": "string",
          "description": "The ID of the Pinterest board."
        },
        "title": {
          "type": "string",
          "description": "The title of the pin."
        },
        "description": {
          "type": "string",
          "description": "The description of the pin."
        },
        "link": {
          "type": "string",
          "description": "The destination link of the pin."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the generated image."
        },
        "status": {
          "type": "string",
          "enum": ["published", "scheduled", "failed"],
          "description": "The status of the pin."
        },
        "publishAt": {
          "type": "string",
          "format": "date-time",
          "description": "The scheduled publish time (if applicable)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the pin was created in the app."
        }
      },
      "required": ["uid", "accountId", "boardId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Collection of user profiles. The document ID must match the user's UID."
    },
    "/pins/{pinId}": {
      "schema": {
        "$ref": "#/entities/Pin"
      },
      "description": "Collection of pins created or scheduled by users."
    }
  }
}
